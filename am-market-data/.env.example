# GitHub Package Registry
GITHUB_PACKAGES_USERNAME=STR
GITHUB_PACKAGES_TOKEN=STR

# PostgreSQL
POSTGRES_PASSWORD=password
POSTGRES_USERNAME=postgres
POSTGRES_URL=jdbc:postgresql://host.docker.internal:5432
POSTGRES_DATABASE=portfolio

MONGODB_URL=mongodb://admin:password@host.docker.internal:27017/market_data?authSource=admin
MONGODB_DATABASE=market_data
MONGODB_USERNAME=admin
MONGODB_PASSWORD=password 

# InfluxDB
INFLUXDB_TOKEN=my-token
INFLUXDB_ORG=am-portfolio
INFLUXDB_BUCKET=market-data
INFLUXDB_URL=http://host.docker.internal:8086
# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=password
GRAFANA_ADMIN_TOKEN=token  

# Redis
REDIS_HOSTNAME=host.docker.internal
REDIS_PASSWORD=password
REDIS_PORT=6379

# Kafka
KAFKA_BOOTSTRAP_SERVERS=host.docker.internal:9092
KAFKA_ZOOKEEPER_CONNECT=host.docker.internal:2181
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://host.docker.internal:9092
KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=PLAINTEXT:PLAINTEXT
KAFKA_INTER_BROKER_LISTENER_NAME=PLAINTEXT
KAFKA_CONSUMER_GROUP_ID=am-market-data-service
KAFKA_CONSUMER_AUTO_OFFSET_RESET=earliest

# Application
STOKUPATE_TOPIC_NAME=am-stock-price-update
NSE_INDICES_TOPIC_NAME=nse-indices-update
NSE_ETF_TOPIC_NAME=nse-etf-update
MARKET_DATA_MAX_RETRIES=3
MARKET_DATA_RETRY_DELAY_MS=1000
MARKET_DATA_THREAD_POOL_SIZE=5
MARKET_DATA_THREAD_QUEUE_CAPACITY=10
MARKET_DATA_MAX_AGE_MINUTES=15

# Upstox
UPSTOX_ACCESS_TOKEN=STR
UPSTOX_API_KEY=STR
UPSTOX_SECRET_KEY=STR
UPSTOX_CODE=STR 

# Zerodha API Configuration
ZERODHA_API_KEY=STR
ZERODHA_API_SECRET=STR
ZERODHA_API_MAX_RETRIES=3
ZERODHA_API_RETRY_DELAY_MS=1000
ZERODHA_API_RETRY_MAX_DURATION_MS=10000
ZERODHA_API_THREAD_POOL_SIZE=5
ZERODHA_API_THREAD_QUEUE_CAPACITY=10
ZERODHA_API_ACCESS_TOKEN=STR
ZERODHA_API_REFRESH_TOKEN=STR

# Ticker Configuration
ZERODHA_TICKER_ENABLED=false
ZERODHA_TICKER_RECONNECT_MAX_RETRIES=10
ZERODHA_TICKER_RECONNECT_INTERVAL=30

# Market Data Configuration
ZERODHA_MARKET_DATA_ENABLED=true
ZERODHA_MARKET_HOURS_START=00:00
ZERODHA_MARKET_HOURS_END=23:59
ZERODHA_MARKET_TIMEZONE=Asia/Kolkata
ZERODHA_NSE_INSTRUMENTS=NSE:NIFTY 50,NSE:BANKNIFTY,NSE:FINNIFTY
ZERODHA_BSE_INSTRUMENTS=BSE:SENSEX,BSE:BANKEX
ZERODHA_INDEX_INSTRUMENTS=NSE:NIFTY 50,NSE:BANKNIFTY,NSE:FINNIFTY,BSE:SENSEX

# JWT Configuration
INTERNAL_JWT_SECRET=STR
JWT_SECRET=STR
JWT_ALGORITHM=HS256
