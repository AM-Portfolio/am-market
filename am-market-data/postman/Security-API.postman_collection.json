{
    "info": {
        "name": "Market Data - Security API",
        "description": "Postman collection for testing Security endpoints including bulk update functionality",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:8093",
            "type": "string"
        },
        {
            "key": "apiPrefix",
            "value": "/v1/securities",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "Search Securities (Simple)",
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "{{baseUrl}}{{apiPrefix}}/search?query=ABB",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "v1",
                        "securities",
                        "search"
                    ],
                    "query": [
                        {
                            "key": "query",
                            "value": "ABB",
                            "description": "Search by symbol or ISIN"
                        }
                    ]
                },
                "description": "Simple text search for securities by symbol or ISIN"
            }
        },
        {
            "name": "Search Securities (Advanced - POST)",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"symbols\": [\"RELIANCE\", \"TCS\", \"INFY\"],\n  \"sector\": \"Technology\",\n  \"industry\": \"IT Services\",\n  \"query\": \"INFY\"\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}{{apiPrefix}}/search",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "v1",
                        "securities",
                        "search"
                    ]
                },
                "description": "Advanced search with filters for sector, industry, and specific symbols. This is a POST to /search with request body."
            }
        },
        {
            "name": "Search by Index",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"index\": \"NIFTY 50\"\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}{{apiPrefix}}/search",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "v1",
                        "securities",
                        "search"
                    ]
                },
                "description": "Search securities by index name. Controller will fetch index constituents automatically."
            }
        },
        {
            "name": "Bulk Update - Dry Run (Preview)",
            "request": {
                "method": "POST",
                "header": [],
                "body": {
                    "mode": "formdata",
                    "formdata": [
                        {
                            "key": "file",
                            "type": "file",
                            "src": "a:/InfraCode/AM-Portfolio-grp/am-market/am-market-data/data/Equity.csv",
                            "description": "CSV or Excel file with security data"
                        },
                        {
                            "key": "fieldsToUpdate",
                            "value": "companyName",
                            "type": "text",
                            "description": "Fields to update"
                        },
                        {
                            "key": "fieldsToUpdate",
                            "value": "sector",
                            "type": "text"
                        },
                        {
                            "key": "matchingStrategy",
                            "value": "STRICT_SYMBOL",
                            "type": "text",
                            "description": "STRICT_ISIN, STRICT_SYMBOL, STRICT_BOTH, LOOSE_ISIN, LOOSE_SYMBOL"
                        },
                        {
                            "key": "dryRun",
                            "value": "true",
                            "type": "text",
                            "description": "Preview changes without saving"
                        }
                    ]
                },
                "url": {
                    "raw": "{{baseUrl}}{{apiPrefix}}/bulk-update",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "v1",
                        "securities",
                        "bulk-update"
                    ]
                },
                "description": "Preview bulk updates without saving changes. Returns what would be updated."
            }
        },
        {
            "name": "Bulk Update - Company Name Only",
