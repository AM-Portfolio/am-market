        {
            "name": "Batch Search - Small (3 queries)",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"queries\": [\n    \"Reliance Industries\",\n    \"INFY\",\n    \"INE040A01034\"\n  ],\n  \"limit\": 3,\n  \"minMatchScore\": 0.7\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}{{apiPrefix}}/batch-search",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "v1",
                        "securities",
                        "batch-search"
                    ]
                },
                "description": "Batch search for multiple securities at once. Returns ISIN, symbol, company name with match scores."
            }
        },
        {
            "name": "Batch Search - Nifty 50 Holdings (Cached 24hr)",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"queries\": [\n    \"Reliance Industries Ltd\",\n    \"HDFC Bank Ltd\",\n    \"Infosys Ltd\",\n    \"ICICI Bank Ltd\",\n    \"Hindustan Unilever Ltd\",\n    \"ITC Ltd\",\n    \"Bharti Airtel Ltd\",\n    \"State Bank of India\",\n    \"Tata Consultancy Services Ltd\",\n    \"Kotak Mahindra Bank Ltd\"\n  ],\n  \"limit\": 1,\n  \"minMatchScore\": 0.8\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}{{apiPrefix}}/batch-search",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "v1",
                        "securities",
                        "batch-search"
                    ]
                },
                "description": "Search index holdings - 24hr cache for better performance. Use for ETF holdings enrichment."
            }
        },
