<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- 
      Pull in all appenders from the observability library.
      This defines JSON_STDOUT, JSON_FILE, and TEXT_STDOUT.
    -->
    <include resource="am-logback-include.xml"/>

    <!--
      THE NUCLEAR FIX:
      Redefine 'JSON_FILE' to be a NOP (No-Operation) appender.
      This is the ONLY way to guarantee the library won't touch the filesystem.
    -->
    <appender name="JSON_FILE" class="ch.qos.logback.core.helpers.NOPAppender"/>

    <!--
      Override the root logger for cloud environments.
      Ensures ONLY JSON_STDOUT (Console) is used in preprod/prod.
    -->
    <springProfile name="!mcp-stdio &amp; !logback-text &amp; !local">
        <root level="INFO">
            <appender-ref ref="JSON_STDOUT"/>
        </root>
    </springProfile>

    <!-- Service-specific logger levels -->
    <logger name="com.am.marketdata" level="INFO"/>
    <logger name="org.springframework"            level="WARN"/>
    <logger name="org.springframework.data.redis" level="WARN"/>
    <logger name="org.hibernate"                  level="WARN"/>
    <logger name="org.apache.kafka"               level="WARN"/>

</configuration>
