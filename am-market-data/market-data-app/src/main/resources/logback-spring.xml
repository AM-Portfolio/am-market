<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- 
      Pull in all appenders from the observability library.
      This defines JSON_STDOUT, JSON_FILE, and TEXT_STDOUT.
    -->
    <include resource="am-logback-include.xml"/>

    <!--
      CRITICAL OVERRIDE for Kubernetes/Cloud:
      The library include unconditionally adds JSON_FILE to the root logger for cloud profiles.
      In Kubernetes, this causes a CrashLoopBackOff because the ./logs directory is not writable.
      
      By redefining the root logger here AFTER the include, we override the library's
      default and ensure ONLY JSON_STDOUT is used in preprod/prod.
    -->
    <springProfile name="!mcp-stdio &amp; !logback-text &amp; !local">
        <root level="INFO">
            <appender-ref ref="JSON_STDOUT"/>
            <!-- JSON_FILE appender removed to prevent CrashLoopBackOff in read-only containers -->
        </root>
    </springProfile>

    <!-- Service-specific logger levels -->
    <logger name="com.am.marketdata" level="INFO"/>
    <logger name="org.springframework"            level="WARN"/>
    <logger name="org.springframework.data.redis" level="WARN"/>
    <logger name="org.hibernate"                  level="WARN"/>
    <logger name="org.apache.kafka"               level="WARN"/>

</configuration>
