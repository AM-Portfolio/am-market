<?xml version="1.0" encoding="UTF-8"?>
<!--
  Logback configuration for am-market-data.

  Delegates to the shared am-observability-lib include file which provides:
    - JSON_STDOUT + JSON_FILE for preprod/prod (default profile)
    - TEXT_STDOUT for local dev (human-readable, no JSON parsing overhead)

  Profile behaviour (controlled by spring.profiles.active):
    - local        → plain text to STDOUT only (easy to read during dev)
    - (default)    → JSON to STDOUT + rolling JSON file (Loki-indexable)
    - caller-off   → composable flag to skip caller info (perf sensitive)

  Why JSON?
    The JSON encoder (logstash-logback-encoder) emits traceId, spanId,
    service, userId, correlationId and flow.* as top-level JSON fields.
    Grafana Loki extracts these automatically, enabling:
      - Direct traceId → Tempo drill-through links
      - LogQL filtering by field (e.g. {traceId="abc123"})
-->
<configuration>

    <!--
      Pull in all appenders and profile-based root logger config from the
      observability library. This single include replaces the manual
      plain-text patterns we had before and is the only change needed
      to unlock JSON-structured logs in Grafana/Loki.
    -->
    <include resource="am-logback-include.xml"/>

    <!--
      Service-specific logger levels.
      These override the root level set inside the include file.
    -->
    <logger name="com.am.marketdata" level="INFO"/>
    <logger name="org.springframework"            level="WARN"/>
    <logger name="org.springframework.data.redis" level="WARN"/>
    <logger name="org.hibernate"                  level="WARN"/>
    <logger name="org.apache.kafka"               level="WARN"/>

</configuration>
