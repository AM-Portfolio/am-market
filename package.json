{
  "name": "am-market",
  "version": "1.0.0",
  "description": "AM Market Orchestrator Root",
  "scripts": {
    "run:parser": "cd am-parser && am run",
    "run:data": "cd am-market-data && am run",
    "run:analysis": "cd market-data-analysis-py && am run",
    "run:ui": "cd am_market_ui && am run",
    "run": "npx -y concurrently -n \"parser,data,analysis,ui\" -c \"magenta,blue,green,yellow\" \"npm run run:parser\" \"npm run run:data\" \"npm run run:analysis\" \"npm run run:ui\"",
    "deploy:parser": "cd am-parser && am deploy",
    "deploy:data": "cd am-market-data && am deploy",
    "deploy": "npx -y concurrently -n \"parser,data\" -c \"magenta,blue\" \"npm run deploy:parser\" \"npm run deploy:data\"",
    "test": "npx -y concurrently \"cd am-parser && am test\" \"cd am-market-data && am test\"",
    "deploy:preprod:parser": "python3 scripts/test_publish.py am-parser --env preprod",
    "deploy:preprod:data": "python3 scripts/test_publish.py am-market-data --env preprod",
    "deploy:local:data": "python3 scripts/local-deploy.py am-market-data",
    "deploy:local:parser": "python3 scripts/local-deploy.py am-parser",
    "runner:deploy:preprod:parser": "python3 scripts/local-deploy.py am-parser --use-runner",
    "runner:deploy:preprod:data": "python3 scripts/local-deploy.py am-market-data --use-runner",
    "vault:sync": "python3 ../am-pipelines/scripts/vault-sync.py --project .env.secrets",
    "publish:test": "python3 scripts/test_publish.py",
    "publish:dry": "python3 scripts/test_publish.py --dry-run",
    "publish:info": "python3 scripts/test_publish.py --info",
    "sdk:market:python": "python3 scripts/test_publish.py --sdk sdk:market:python",
    "sdk:market:java": "python3 scripts/test_publish.py --sdk sdk:market:java",
    "sdk:market:flutter": "python3 scripts/test_publish.py --sdk sdk:market:flutter",
    "sdk:parser:python": "python3 scripts/test_publish.py --sdk sdk:parser:python",
    "sdk:parser:java": "python3 scripts/test_publish.py --sdk sdk:parser:java",
    "sdk:parser:flutter": "python3 scripts/test_publish.py --sdk sdk:parser:flutter",
    "common:data:java": "python3 scripts/test_publish.py --sdk module:common:java",
    "am-common-investment-data:publish": "python3 scripts/test_publish.py --sdk module:common:java"
  }
}
