# ─────────────────────────────────────────────────────────────────────────────
# .env.template — Copy to .env and fill in your real values.
# .env is gitignored — it will NEVER be committed.
# cp .env.template .env
# ─────────────────────────────────────────────────────────────────────────────

# ── FOR PYTHON SDKs (GitHub Releases) ────────────────────────────────────────
# Needs 'repo' (full) scope.
# Create at: https://github.com/settings/tokens/new
#   ✅ Check:  repo  (Full control of private repositories)
GITHUB_RELEASE_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── FOR JAVA / MAVEN (GitHub Packages Maven Registry) ────────────────────────
# Needs 'write:packages' scope.
# Create at: https://github.com/settings/tokens/new
#   ✅ Check:  write:packages
GITHUB_PACKAGES_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_PACKAGES_USERNAME=your-github-username

# ── OPTIONAL ──────────────────────────────────────────────────────────────────
# Override the repository to publish to (auto-detected from git remote if omitted)
# GITHUB_REPOSITORY=AM-Portfolio/am-market
